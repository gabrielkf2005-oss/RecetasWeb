<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Receta</title>
    <style>
        :root {
            --bg-body: #f8f9fa;
            --bg-card: #ffffff;
            --text-main: #333333;
            --text-muted: #555555;
            --border-color: #eee;
            --shadow: rgba(0,0,0,0.05);
        }

        [data-theme="dark"] {
            --bg-body: #121212;
            --bg-card: #1e1e1e;
            --text-main: #f8f9fa;
            --text-muted: #b0b0b0;
            --border-color: #333333;
            --shadow: rgba(0,0,0,0.3);
        }

        body { font-family: Arial, sans-serif; margin: 20px; background: var(--bg-body); color: var(--text-main); transition: background 0.3s, color 0.3s; display: flex; justify-content: center; align-items: center; min-height: 90vh; }
        .card { background: var(--bg-card); padding: 30px; border-radius: 8px; box-shadow: 0 4px 12px var(--shadow); width: 100%; max-width: 500px; transition: background 0.3s; }
        h3 { margin-top: 0; color: var(--text-main); font-size: 24px; margin-bottom: 20px; text-align: center; }
        .form-group { margin-bottom: 15px; }
        label { display: block; margin-bottom: 6px; color: var(--text-muted); font-weight: bold; font-size: 14px; }
        input, textarea, select { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; background: var(--bg-card); color: var(--text-main); font-size: 15px; }
        .btn-container { display: flex; gap: 10px; margin-top: 20px; }
        button { flex: 1; padding: 12px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 15px; font-weight: bold; }
        button.btn-secondary { background: #6c757d; }
        a { text-decoration: none; display: block; flex: 1; }
    </style>
</head>
<body>

    <div class="card">
        <h3>Modificar Receta</h3>
        <form action="/recetas/editar/<%= receta._id %>" method="POST">
            <div class="form-group">
                <label>Nombre de la Receta:</label>
                <input type="text" name="nombre" value="<%= receta.nombre %>" required>
            </div>
            
            <div class="form-group">
                <label>Categoría:</label>
                <select name="categoria" required>
                    <% categorias.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= receta.categoria && receta.categoria.toString() === cat._id.toString() ? 'selected' : '' %> >
                            <%= cat.nombre %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label>Ingredientes:</label>
                <textarea name="ingredientes" rows="4" required><%= receta.ingredientes %></textarea>
            </div>

            <div class="form-group">
                <label>Instrucciones:</label>
                <textarea name="instrucciones" rows="5" required><%= receta.instrucciones %></textarea>
            </div>

            <div class="btn-container">
                <a href="/dashboard"><button type="button" class="btn-secondary">Volver</button></a>
                <button type="submit">Actualizar Cambios</button>
            </div>
        </form>
    </div>

    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
        }
    </script>
</body>
</html>